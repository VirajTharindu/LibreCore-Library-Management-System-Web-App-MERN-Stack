# LibreCore Server Environment Configuration
# Copy this file to '.env' and fill in your secure values before running the application.

# Server Configuration
PORT=4000

# Authentication (Required)
# Generate a strong random string for your JWT secret.
JWT_SECRET=your_super_secret_jwt_key_here

# Database Configuration (For Future MongoDB Adapter)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/librecore?retryWrites=true&w=majority

# Initial Admin Seeding (Used by scripts/create-admin.js)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=Administrator
